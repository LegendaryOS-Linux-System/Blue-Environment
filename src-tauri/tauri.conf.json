{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Blue Environment",
  "version": "0.6.0",
  "identifier": "org.legendaryos.blue-environment",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "mkdir -p src-tauri/icons && cp images/icon.png src-tauri/icons/icon.png && npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Blue Environment",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "/usr/share/**",
          "/tmp/**",
          "/var/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  },
  "plugins": {
    "fs": {},
    "shell": {
      "open": true
    }
  }
}
