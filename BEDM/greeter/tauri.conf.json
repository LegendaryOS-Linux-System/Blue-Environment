{
  "build": {
    "beforeDevCommand": "cd ../bedm-ui && npm run dev",
    "beforeBuildCommand": "cd ../bedm-ui && npm run build",
    "devPath": "http://localhost:5174",
    "distDir": "../bedm-ui/dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "bedm-greeter",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "fs": { "all": true, "scope": ["/etc/bedm/**", "/run/bedm/**", "/usr/share/**", "/home/**", "/var/lib/bedm/**"] },
      "path": { "all": true },
      "shell": { "all": false },
      "process": { "all": false }
    },
    "bundle": {
      "active": false,
      "identifier": "org.hackeros.bedm-greeter",
      "icon": ["icons/icon.png"]
    },
    "security": { "csp": null },
    "windows": [
      {
        "fullscreen": true,
        "resizable": false,
        "title": "BEDM Login",
        "width": 1920,
        "height": 1080,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ]
  }
}
