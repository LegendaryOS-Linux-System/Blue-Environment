{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bedm-greeter",
  "version": "1.0.0",
  "identifier": "org.hackeros.bedm-greeter",
  "build": {
    "beforeDevCommand": "cd ../bedm-ui && npm run dev",
    "beforeBuildCommand": "mkdir -p icons && cp ../../images/icon.png icons/icon.png && cd ../bedm-ui && npm run build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../bedm-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "BEDM Login",
        "width": 1920,
        "height": 1080,
        "resizable": false,
        "fullscreen": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": [
          "/etc/bedm/**",
          "/run/bedm/**",
          "/usr/share/**",
          "/home/**",
          "/var/lib/bedm/**"
        ]
      }
    }
  }
}
